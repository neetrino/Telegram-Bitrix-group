NODE_ENV=development
STORAGE_ROOT=./storage

# Bitrix webhook — header X-Webhook-Secret or ?secret=
BITRIX_WEBHOOK_SECRET=change-me-min-8-chars

# Telegram (my.telegram.org) — user account, not bot
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Session — one of:
TELEGRAM_SESSION_STRING=
# TELEGRAM_SESSION_FILE=./telegram.session.txt

# Comma-separated Telegram @usernames (without @) added to every webhook
TELEGRAM_DEFAULT_PARTICIPANTS=

WEBHOOK_DEDUP_MAX=2000
FILE_DOWNLOAD_MAX_BYTES=50000000
FILE_DOWNLOAD_TIMEOUT_MS=120000
